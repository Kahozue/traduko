{
  "plugins": ["stylelint-declaration-strict-value"],
  "ignoreFiles": ["src/styles/tokens.css"],
  "rules": {
    "scale-unlimited/declaration-strict-value": [
      ["/color$/", "background", "font-size", "border-radius", "font-family"],
      {
        "ignoreValues": [
          "transparent",
          "inherit",
          "currentColor",
          "none",
          "0",
          "50%",
          "/^linear-gradient/",
          "/^repeating-linear-gradient/"
        ],
        "message": "Use design tokens (var(--…)); see internal/design-language.md"
      }
    ]
  }
}
