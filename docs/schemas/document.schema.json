{
  "$defs": {
    "Block": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "heading",
            "paragraph",
            "code",
            "blank",
            "other"
          ],
          "title": "Kind",
          "type": "string"
        },
        "translate": {
          "title": "Translate",
          "type": "boolean"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "anchor": {
          "default": "",
          "title": "Anchor",
          "type": "string"
        }
      },
      "required": [
        "id",
        "kind",
        "translate",
        "text"
      ],
      "title": "Block",
      "type": "object"
    },
    "Chapter": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "default": "",
          "title": "Title",
          "type": "string"
        },
        "href": {
          "default": "",
          "title": "Href",
          "type": "string"
        },
        "blocks": {
          "items": {
            "$ref": "#/$defs/Block"
          },
          "title": "Blocks",
          "type": "array"
        }
      },
      "required": [
        "id"
      ],
      "title": "Chapter",
      "type": "object"
    }
  },
  "properties": {
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "format": {
      "enum": [
        "markdown",
        "txt",
        "html",
        "epub"
      ],
      "title": "Format",
      "type": "string"
    },
    "chapters": {
      "items": {
        "$ref": "#/$defs/Chapter"
      },
      "title": "Chapters",
      "type": "array"
    }
  },
  "required": [
    "format"
  ],
  "title": "DocumentDoc",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
