{
  "$defs": {
    "TranslatedBlock": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "id",
        "text"
      ],
      "title": "TranslatedBlock",
      "type": "object"
    },
    "TranslatedChunk": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "status": {
          "enum": [
            "translated",
            "failed",
            "pending"
          ],
          "title": "Status",
          "type": "string"
        },
        "blocks": {
          "items": {
            "$ref": "#/$defs/TranslatedBlock"
          },
          "title": "Blocks",
          "type": "array"
        }
      },
      "required": [
        "id",
        "status"
      ],
      "title": "TranslatedChunk",
      "type": "object"
    }
  },
  "properties": {
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "chunks": {
      "items": {
        "$ref": "#/$defs/TranslatedChunk"
      },
      "title": "Chunks",
      "type": "array"
    }
  },
  "title": "DocTranslationDoc",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
